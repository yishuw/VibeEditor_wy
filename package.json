{
  "name": "vibeeditor",
  "version": "0.1.0",
  "private": true,
  "description": "VibeEditor - An AI-powered code editor with Monaco Editor, supporting both server and Electron deployment",
  "workspaces": [
    "packages/core",
    "packages/server",
    "packages/electron",
    "packages/web"
  ],
  "scripts": {
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "dev:electron": "npm run dev -w packages/electron",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build:core": "npm run build -w packages/core",
    "build:web": "npm run build -w packages/web",
    "build:server": "npm run build -w packages/server",
    "build:electron": "npm run build -w packages/electron",
    "build:all": "npm run build:core && npm run build:web && npm run build:server && npm run build:electron",
    "lint": "eslint packages/*/src --ext .ts,.tsx,.vue",
    "typecheck": "tsc -b",
    "postinstall": "npm run build:core"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "prettier": "^3.2.4",
    "concurrently": "^8.2.2"
  }
}
